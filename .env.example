# =============================================================================
# data-orchestration-airflow — Environment Variables Template
# =============================================================================
#
# USAGE
# -----
#   1. Copy this file to .env in the project root:
#        cp .env.example .env
#
#   2. Fill in every value marked with <angle brackets> or left blank.
#      Never leave credentials empty in a production environment.
#
#   3. Generate the Fernet and secret keys (one-time setup):
#        python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
#        python -c "import secrets; print(secrets.token_hex(32))"
#
#   4. Start the stack:
#        docker compose up -d
#
# SECURITY
# --------
#   - The .env file is git-ignored and must NEVER be committed.
#   - Never share the Fernet key or secret key — they protect encrypted
#     credentials stored in the Airflow metadata database.
#   - Rotate the Fernet key by re-encrypting all stored connection passwords
#     using `airflow rotate-fernet-key`.
#   - In production CI/CD, inject these values via secrets management
#     (AWS Secrets Manager, GitHub Actions secrets, HashiCorp Vault).
# =============================================================================


# =============================================================================
# Airflow System Configuration
# =============================================================================

# Required by Airflow when running on Linux to set correct file ownership
# inside the container. Find your UID with: id -u
# On Windows with Docker Desktop, use 50000 (the default Airflow UID).
AIRFLOW_UID=50000

# Fernet key for encrypting connection passwords and Airflow variables
# stored in the metadata database.
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW_FERNET_KEY=

# Secret key for signing Airflow webserver Flask session cookies.
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
AIRFLOW_SECRET_KEY=

# Host port for the Airflow webserver. Access at http://localhost:<port>
AIRFLOW_WEBSERVER_PORT=8080

# =============================================================================
# Airflow Admin User
# =============================================================================
# Created automatically by airflow-init on first `docker compose up`.
# Used to log in to the Airflow UI.

AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=
AIRFLOW_ADMIN_EMAIL=admin@example.com


# =============================================================================
# PostgreSQL — Airflow Metadata Database
# =============================================================================
# Used exclusively by Airflow to store DAG state, task instances, XCom,
# connections, and variables. Do NOT use this database for ETL data.

POSTGRES_AIRFLOW_USER=airflow
POSTGRES_AIRFLOW_PASSWORD=
POSTGRES_AIRFLOW_DB=airflow


# =============================================================================
# PostgreSQL — ETL Data Database
# =============================================================================
# Stores the fact and dimension tables produced by the economic-data-etl
# pipeline. Separate from the Airflow metadata DB by design.

POSTGRES_ETL_USER=etl_user
POSTGRES_ETL_PASSWORD=
POSTGRES_ETL_DB=economic_data

# Host port for the ETL database. Use 5433 to avoid conflict with any
# Postgres instance running locally on the standard 5432 port.
# Connect with: psql -h localhost -p 5433 -U etl_user -d economic_data
POSTGRES_ETL_PORT=5433


# =============================================================================
# ETL API Keys
# =============================================================================
# These values are passed into the Airflow task execution environment
# and will be consumed by the economic-data-etl extract functions in Phase 2.

# FRED API key — free registration at:
# https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# BLS API key — free registration at:
# https://data.bls.gov/registrationEngine/
BLS_API_KEY=


# =============================================================================
# SMTP Alerting (Gmail)
# =============================================================================
# Required for email_on_failure alerts and SLA miss notifications.
#
# SETUP
# -----
# 1. Enable 2-Factor Authentication on your Google account.
# 2. Go to https://myaccount.google.com/apppasswords
# 3. Generate an App Password for "Mail" / "Other (custom name)".
# 4. Paste the 16-character password (no spaces) as AIRFLOW_SMTP_PASSWORD.
#
# NOTE: Use your Gmail address as both the SMTP user and the alert sender.
# Alerts will be sent FROM and TO AIRFLOW_SMTP_USER unless AIRFLOW_ADMIN_EMAIL
# is set to a different address.

AIRFLOW_SMTP_USER=your-email@gmail.com
AIRFLOW_SMTP_PASSWORD=
